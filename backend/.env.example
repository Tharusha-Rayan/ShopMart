# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://tharusharayan15_db_user:MFTCTKJUXxRpHuke@cluster0.btuxyap.mongodb.net/?appName=Cluster0

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# LLM / RAG Chatbot (Optional - enables AI chat generation)
# LLM_PROVIDER can be: openai | google
LLM_PROVIDER=google

# OpenAI-compatible settings (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Google AI Studio Gemini settings (if LLM_PROVIDER=google)
GOOGLE_AI_API_KEY=your_google_ai_studio_api_key
GOOGLE_MODEL=gemini-1.5-flash
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
